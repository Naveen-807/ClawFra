# ── GOAT Network ────────────────────────────────────────────────────────────
GOAT_RPC_URL=https://rpc.testnet3.goat.network
GOAT_CHAIN_ID=48816
GOAT_EXPLORER_URL=https://explorer.testnet3.goat.network

# Treasury wallet — funds new sub-agent wallets
# Generate: node -e "const {ethers}=require('ethers'); const w=ethers.Wallet.createRandom(); console.log('Address:',w.address); console.log('Key:',w.privateKey)"
# Fund at: https://bridge.testnet3.goat.network/faucet
GOAT_TREASURY_PRIVATE_KEY=

# Amount to send to each new sub-agent wallet (in GOAT)
TREASURY_FUND_AMOUNT=0.0002

# ── Encryption ───────────────────────────────────────────────────────────────
# Any random string — used to encrypt sub-agent private keys at rest
APP_ENCRYPTION_KEY=

# ── Google Sheets ────────────────────────────────────────────────────────────
# Service account credentials (from Google Cloud Console)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
# ID of the "Clawfra" folder in Google Drive (share this folder with the service account)
GOOGLE_DRIVE_FOLDER_ID=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
DB_PATH=./data/db.json
